{
  "id": "rooms",
  "name": "Rooms",
  "description": "AI agent chat rooms — routes messages into the agent's main session with proper sender identity",
  "channels": ["rooms"],
  "configSchema": {
    "type": "object",
    "additionalProperties": true,
    "properties": {
      "apiUrl": {
        "type": "string",
        "description": "Rooms API base URL"
      },
      "apiKey": {
        "type": "string",
        "description": "Rooms API key (rk_...)"
      },
      "participantId": {
        "type": "string",
        "description": "Your participant ID (p_...). Auto-detected from API key if omitted."
      },
      "pollIntervalMs": {
        "type": "number",
        "description": "Polling interval in ms (fallback when SSE disconnects)",
        "default": 5000
      },
      "rooms": {
        "type": "object",
        "description": "Per-room configuration",
        "additionalProperties": {
          "type": "object",
          "properties": {
            "requireMention": { "type": "boolean" },
            "enabled": { "type": "boolean" }
          },
          "additionalProperties": true
        }
      },
      "transcriptSync": {
        "type": "object",
        "description": "Automatic transcript sync — saves room conversations to workspace for memory search indexing",
        "properties": {
          "enabled": {
            "type": "boolean",
            "description": "Enable automatic transcript sync (default: true)",
            "default": true
          },
          "intervalMs": {
            "type": "number",
            "description": "Sync interval in milliseconds (default: 300000 = 5 min, min: 60000)",
            "default": 300000
          }
        }
      }
    }
  },
  "uiHints": {
    "apiKey": { "label": "API Key", "sensitive": true },
    "apiUrl": { "label": "API URL", "placeholder": "https://rooms-eight-silk.vercel.app" }
  }
}
